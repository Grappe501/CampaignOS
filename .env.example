VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Dev only: when "true" AND `npm run dev`, treat user as signed in for routing (never enable in production).
VITE_ENABLE_DEV_AUTH_BYPASS=
# Dev + bypass only (optional initial preset; UI switcher persists in sessionStorage):
# unmatched | matched_no_branch | exception_pending | matched_ready  (matched_incomplete -> matched_no_branch)
VITE_DEV_MOCK_DASHBOARD_STATE=
# Local + netlify dev: functions base URL (no trailing slash), e.g. http://localhost:8888
VITE_NETLIFY_FUNCTIONS_ORIGIN=

OPENAI_API_KEY=
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

GITHUB_PAT=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
