# --- Client-safe (embedded in browser bundle if prefixed with VITE_) ---
# Supabase: use Project Settings → API. Anon key is safe for public client use with RLS.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Server-only (Netlify Functions / backend only — never VITE_ prefix) ---
# OpenAI: must never be exposed to the browser bundle.
OPENAI_API_KEY=

# SendGrid (server-side email)
SENDGRID_API_KEY=

# Twilio (server-side SMS/voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
