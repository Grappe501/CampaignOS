VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Dev only: when "true" AND `npm run dev`, treat user as signed in for routing (never enable in production).
VITE_ENABLE_DEV_AUTH_BYPASS=
# Dev + bypass only (optional initial preset; UI switcher persists in sessionStorage):
# unmatched | matched_no_branch | exception_pending | matched_ready  (matched_incomplete -> matched_no_branch)
VITE_DEV_MOCK_DASHBOARD_STATE=
# Local + netlify dev: functions base URL (no trailing slash), e.g. http://localhost:8888
VITE_NETLIFY_FUNCTIONS_ORIGIN=

# Required for Agent Jones (netlify/functions/agent-jones). Server-only — never VITE_.
# Production: set OPENAI_API_KEY in Netlify UI and redeploy. Optional: OPENAI_MODEL (default gpt-4o-mini).
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Server-only civics / campaign intelligence (never VITE_) — see docs/campaign-api-keys.md
GOOGLE_CIVIC_API_KEY=
GOOGLE_API_KEY=
OPENCAGE_API_KEY=
API_DOT_GOV_KEY=
OPENSTATES_API_KEY=
FOURSQUARE_API_KEY=
NEWSAPI_API_KEY=
GUARDIAN_API_KEY=
CONGRESS_GOV_API_KEY=

SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

GITHUB_PAT=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
